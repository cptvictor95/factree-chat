## Component Conventions

```typescript
// ✅ Named export, explicit return type, props interface
interface QueueItemRowProps {
  item: Types.QueueItem;
  isOwn: boolean;
  onRemove: (id: bigint) => void;
}

export function QueueItemRow({ item, isOwn, onRemove }: QueueItemRowProps): JSX.Element {
  // ...
}

// ❌ Default export
export default function QueueItemRow() { ... }

// ❌ Missing return type
export function QueueItemRow({ item }: QueueItemRowProps) { ... }
```

